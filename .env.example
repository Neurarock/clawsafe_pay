# ── Telegram Bot (user_auth) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Shared secrets ────────────────────────────────────────────────────────────
# HMAC secret shared between user_auth and publisher_service
HMAC_SECRET=change-me-to-a-random-32-byte-hex

# ── user_auth service ─────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=8000
AUTH_REQUEST_TTL_SECONDS=300
SIGNER_SERVICE_CALLBACK_URL=http://localhost:8001/auth/callback

# ── publisher_service ─────────────────────────────────────────────────────────
PUBLISHER_SERVICE_PORT=8002
PUBLISHER_API_KEY=change-me-to-a-random-32-byte-hex

# Downstream service URLs
REVIEWER_SERVICE_URL=http://localhost:8003
USER_AUTH_SERVICE_URL=http://localhost:8000
SIGNER_SERVICE_URL=http://localhost:8001

# Signer wallet (the address that will sign and broadcast transactions)
SIGNER_FROM_ADDRESS=0xYourSignerWalletAddress

# Sepolia RPC endpoint (public or Alchemy/Infura)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Policy overrides (optional — defaults are conservative)
POLICY_MAX_AMOUNT_WEI=50000000000000000
POLICY_RECIPIENT_ALLOWLIST=*
POLICY_TIP_WEI=1500000000

# Approval polling
APPROVAL_POLL_INTERVAL_SECONDS=3
APPROVAL_TIMEOUT_SECONDS=120

# ── Flock API — injection filter ──────────────────────────────────────────────
# Get your API key at https://platform.flock.io
FLOCK_API_KEY=sk-your-flock-api-key
# Model to use for injection scoring (must be available in your Flock account)
FLOCK_MODEL=gemini-2.0-flash
# Reject intents with an injection score >= this threshold (0-10 scale, default 7)
INJECTION_BLOCK_THRESHOLD=7
